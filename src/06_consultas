-- RELATÓRIO 4: CURSOS MAIS CAROS E MAIS BARATOS (COM UNION E EXTREMOS)
-- Itens da Checklist SQL atendidos: 
-- 12 (MAX), 13 (MIN), 24 (UNION)

SELECT 
    Titulo AS Curso_Destaque, 
    Valor, 
    'MAIOR PREÇO DA PLATAFORMA' AS Categoria 
FROM Curso 
WHERE Valor = (SELECT MAX(Valor) FROM Curso)
UNION
SELECT 
    Titulo AS Curso_Destaque, 
    Valor, 
    'MENOR PREÇO DA PLATAFORMA' AS Categoria 
FROM Curso 
WHERE Valor = (SELECT MIN(Valor) FROM Curso);


