-- RELATÓRIO GERAL DE ESTUDANTES
-- Itens da Checklist SQL atendidos: 
-- 6 (SELECT-FROM-WHERE), 11 (INNER JOIN), 21 (ORDER BY)

SELECT 
    M.ID_Matricula AS Registro_Matricula,
    U.Nome AS Nome_do_Estudante,
    U.Email AS Contato_Email,
    M.Status AS Situacao_no_Curso
FROM Usuario U
INNER JOIN Aluno AL 
    ON U.CPF = AL.CPF_Usuario
INNER JOIN Matricula M 
    ON AL.CPF_Usuario = M.CPF_Aluno
ORDER BY 
    U.Nome ASC;


-- RELATÓRIO 2: ENGAJAMENTO DE ALUNOS
-- Itens da Checklist SQL atendidos: 
-- 16 (LEFT OUTER JOIN), 14 (AVG), 15 (COUNT), 22 (GROUP BY)
SELECT 
    U.Nome AS Nome_do_Aluno,
    A.Status AS Status_da_Assinatura,
    COUNT(M.ID_Matricula) AS Quantidade_Cursos_Matriculados,
    NVL(AVG(M.Progresso), 0) AS Media_Progresso_Total
FROM Usuario U
INNER JOIN Aluno AL ON U.CPF = AL.CPF_Usuario
LEFT JOIN Assinatura A ON AL.CPF_Usuario = A.CPF_Aluno
LEFT JOIN Matricula M ON AL.CPF_Usuario = M.CPF_Aluno
WHERE U.Tipo = 'ALUNO'
GROUP BY U.Nome, A.Status
ORDER BY Quantidade_Cursos_Matriculados DESC;


-- RELATÓRIO 3: ALUNOS NOS CURSOS PREMIUM (VIEW)
-- Itens da Checklist SQL atendidos: 
-- 25 (CREATE VIEW), 18 (SUBCONSULTA COM IN), 17 (SUBCONSULTA OPERADOR RELACIONAL)
CREATE OR REPLACE VIEW v_alunos_cursos_caros AS
SELECT 
    M.ID_Matricula,
    U.Nome AS Nome_do_Aluno
FROM Matricula M
INNER JOIN Usuario U ON M.CPF_Aluno = U.CPF
WHERE M.ID_Curso IN (
    SELECT ID_Curso FROM Curso WHERE Valor > 250
);
SELECT * FROM v_alunos_cursos_caros;

-- REGRA 1: VALIDAÇÃO DE DATA DE AVALIAÇÃO (GATILHO)
-- Itens da Checklist PL atendidos: 
-- 20 (TRIGGER LINHA), 6 (%TYPE), 13 (SELECT INTO), 8 (IF), 15 (EXCEPTION)
CREATE OR REPLACE TRIGGER trg_valida_data_aval
BEFORE INSERT OR UPDATE ON Avaliacao
FOR EACH ROW
DECLARE
    v_data_matricula Matricula.Data_Matricula%TYPE; 
BEGIN
    SELECT Data_Matricula INTO v_data_matricula
    FROM Matricula
    WHERE CPF_Aluno = :NEW.CPF_Aluno AND ID_Curso = :NEW.ID_Curso;

    IF :NEW.Data_Avaliacao < v_data_matricula THEN
        RAISE_APPLICATION_ERROR(-20001, 'Fraude: A avaliação não pode ser anterior à matrícula!');
    END IF;
EXCEPTION
    WHEN NO_DATA_FOUND THEN
        RAISE_APPLICATION_ERROR(-20002, 'Erro: O aluno não está matriculado neste curso.');
END;


-- REGRA 2: SISTEMA DE FECHAMENTO DE SEMESTRE (PACOTE E CURSOR)
-- Itens da Checklist PL atendidos: 
-- 17 (CREATE PACKAGE), 18 (PACKAGE BODY), 4 (PROCEDURE), 14 (CURSOR EXPLÍCITO), 7 (%ROWTYPE), 10 (LOOP EXIT WHEN)
CREATE OR REPLACE PACKAGE PKG_GESTAO_ACADEMICA AS
    PROCEDURE Atualizar_Status_Conclusao;
END PKG_GESTAO_ACADEMICA;
/

CREATE OR REPLACE PACKAGE BODY PKG_GESTAO_ACADEMICA AS
    PROCEDURE Atualizar_Status_Conclusao IS
        CURSOR c_matriculas IS
            SELECT ID_Matricula FROM Matricula
            WHERE Status = 'ATIVA' AND Progresso = 100;
        v_matricula c_matriculas%ROWTYPE; 
    BEGIN
        FOR v_matricula IN c_matriculas LOOP
            UPDATE Matricula
            SET Status = 'CONCLUIDO'
            WHERE ID_Matricula = v_matricula.ID_Matricula;
        END LOOP;
        COMMIT;
    END Atualizar_Status_Conclusao;
END PKG_GESTAO_ACADEMICA;


-- REGRA 3: CÁLCULO DE DESCONTO DE MENSALIDADE (FUNÇÃO)
-- Itens da Checklist PL atendidos: 
-- 5 (CREATE FUNCTION), 16 (Parâmetros IN), 8 (IF ELSIF)
CREATE OR REPLACE FUNCTION Calcular_Desconto_Curso (
    p_cpf_aluno IN Aluno.CPF_Usuario%TYPE,
    p_valor_curso IN Curso.Valor%TYPE
) RETURN NUMBER IS
    v_id_plano Assinatura.ID_Plano%TYPE;
    v_valor_final NUMBER(10,2);
BEGIN
    BEGIN
        SELECT ID_Plano INTO v_id_plano
        FROM Assinatura
        WHERE CPF_Aluno = p_cpf_aluno AND Status = 'ATIVA'
        FETCH FIRST 1 ROWS ONLY; 
    EXCEPTION
        WHEN NO_DATA_FOUND THEN v_id_plano := 0; 
    END;

    IF v_id_plano = 2 THEN v_valor_final := p_valor_curso * 0.80; 
    ELSIF v_id_plano = 1 THEN v_valor_final := p_valor_curso * 0.95; 
    ELSE v_valor_final := p_valor_curso; 
    END IF;

    RETURN v_valor_final;
END;


