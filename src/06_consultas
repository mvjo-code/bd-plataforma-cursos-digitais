  -- REGRA 4: SISTEMA DE AUDITORIA DE USUÁRIOS (BLOCO ANÔNIMO COM ARRAYS)
-- Itens da Checklist PL atendidos: 
-- 3 (BLOCO ANÔNIMO), 1 (USO DE RECORD), 2 (ESTRUTURA TABLE), 11 (WHILE LOOP)

DECLARE
    -- 1. Cria um "RECORD" (funciona como uma Struct em C++ ou um Dicionário no Python)
    TYPE t_auditoria IS RECORD (
        cpf_alvo VARCHAR2(11), 
        acao VARCHAR2(50)
    );
    
    -- 2. Cria uma "TABLE" (funciona como uma Lista/Array em memória)
    TYPE t_tabela_auditoria IS TABLE OF t_auditoria INDEX BY BINARY_INTEGER;
    
    v_lista_logs t_tabela_auditoria;
    v_contador NUMBER := 1;
BEGIN
    -- Simulando a Maisa Vitória, ou outro admin, registrando logs de auditoria manualmente
    v_lista_logs(1).cpf_alvo := '33333333333'; 
    v_lista_logs(1).acao := 'Verificação de Fraude';
    
    v_lista_logs(2).cpf_alvo := '22222222222'; 
    v_lista_logs(2).acao := 'Reset de Senha';

    -- 3. WHILE LOOP (Percorre o nosso Array em memória e imprime na tela)
    WHILE v_contador <= v_lista_logs.COUNT LOOP
        DBMS_OUTPUT.PUT_LINE('LOG ' || v_contador || ': CPF ' || v_lista_logs(v_contador).cpf_alvo || ' - ' || v_lista_logs(v_contador).acao);
        v_contador := v_contador + 1;
    END LOOP;
END;


